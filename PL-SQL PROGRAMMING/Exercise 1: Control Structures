Scenario 1: Apply 1% Interest Rate Discount for Customers Above 60

DECLARE
BEGIN
    FOR cust IN (
        SELECT CustomerID
        FROM Customers
        WHERE Age > 60
    ) LOOP

        UPDATE Loans
        SET InterestRate = InterestRate - 1
        WHERE CustomerID = cust.CustomerID;

    END LOOP;

    COMMIT;
END;


Scenario 2: Set VIP Status for Customers with Balance Over $10,000

DECLARE
BEGIN
    UPDATE Customers
    SET IsVIP = 'TRUE'
    WHERE Balance > 10000;

    COMMIT;
END;

Scenario 3: Print Reminder Messages for Loans Due Within Next 30 Days

SET SERVEROUTPUT ON;

DECLARE
    v_name Customers.Name%TYPE;
BEGIN
    FOR loan_rec IN (
        SELECT c.Name, l.LoanID, l.DueDate
        FROM Customers c
        JOIN Loans l
        ON c.CustomerID = l.CustomerID
        WHERE l.DueDate BETWEEN SYSDATE AND SYSDATE + 30
    ) LOOP

        DBMS_OUTPUT.PUT_LINE(
            'Reminder: Dear ' || loan_rec.Name ||
            ', your loan (ID: ' || loan_rec.LoanID ||
            ') is due on ' || TO_CHAR(loan_rec.DueDate, 'DD-MON-YYYY')
        );

    END LOOP;
END;



